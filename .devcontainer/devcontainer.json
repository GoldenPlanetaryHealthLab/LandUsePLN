{
  "name": "LandUsePLN",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },

  "remoteUser": "vscode",
  "containerUser": "vscode",

  "workspaceFolder": "/workspaces/LandUsePLN",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "REditorSupport.r",
        "quarto.quarto"
      ],
      "settings": {
        "r.rterm.linux": "/home/vscode/.local/bin/arf",
        "r.bracketedPaste": true,
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  }
}